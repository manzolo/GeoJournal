    <string name="onboarding_subtitle">GeoJournal works in two modes. I recommend reading before choosing.</string>
    <string name="onboarding_guest_title">On device only</string>
    <string name="onboarding_guest_body">The most private option. Your places, photos, reminders and visits stay only on this device — no server, no cloud, not even I as the developer can see them. To avoid losing your data, export a periodic backup from Profile → Export backup.</string>
    <string name="onboarding_guest_badge">⭐ Recommended for privacy · No registration</string>
    <string name="onboarding_cloud_title">Synced to the cloud</string>
    <string name="onboarding_cloud_body">With a Google account you can save your data online — but nothing is sent automatically. You decide what to share: enable or disable points, photos, reminders and visits individually from Profile → Sync &amp; Privacy. Everything is off by default. Other users can never access your data. However, as the developer I have technical access to stored data. If maximum privacy matters to you, use guest mode.</string>
    <string name="onboarding_cloud_badge">Opt-in backup · Everything OFF by default</string>
    <string name="onboarding_open_source_note">🔓 GeoJournal is open source (AGPL-3.0): the code is public on GitHub and anyone can verify what it does with your data. You don\'t have to take my word for it.</string>
    <string name="onboarding_crashlytics_note">Even in guest mode, if the app crashes unexpectedly, anonymous data is automatically sent to help me fix the issue. No personal information is included. (via Firebase Crashlytics)</string>
    <string name="onboarding_cta">Got it</string>
    <string name="profile_data_info_button">How we handle your data</string>
    <string name="profile_help_button">Feature guide</string>

    <!-- Help screen -->
    <string name="help_title">How to use GeoJournal</string>
    <string name="help_subtitle">A quick guide to the main features</string>
    <string name="help_add_point_title">Save a point</string>
    <string name="help_add_point_body">Use the + button to save your current position on the map. You can set a title, description, a custom emoji and attach photos.</string>
    <string name="help_add_point_badge">+ button</string>
    <string name="help_track_title">Record a GPS track</string>
    <string name="help_track_body">From the point detail screen, start recording to trace your route. The service keeps running even with the screen off. At the end, the route is saved and can be shown as a coloured line on the map.</string>
    <string name="help_track_badge">Point detail → Start tracking</string>
    <string name="help_details_title">Point information</string>
    <string name="help_details_body">Each point can hold: tags for categorisation, a star rating, personal notes (local only, never shared), reminders with notifications, and one or more KML tracks. You\'ll find these fields under \"Additional details\" in the edit screen.</string>
    <string name="help_details_badge">Tags · Rating · Notes · Reminders · GPS Tracks</string>
    <string name="help_backup_title">Backup and restore</string>
    <string name="help_backup_body">From Profile you can export all your points to a ZIP file and re-import them at any time. Automatic backup periodically saves your data securely, and to Google Drive if configured.</string>
    <string name="help_backup_badge">Profile → Backup</string>
    <string name="help_share_title">Share a point</string>
    <string name="help_share_body">Any point can be shared with whoever you like. The file includes the main information and attached photos. The recipient can import it directly into GeoJournal. Personal notes and GPS tracks are excluded for privacy.</string>
    <string name="help_share_badge">Point detail → Share</string>
    <string name="help_cta">Got it!</string>

    <!-- Sync & Privacy -->
    <string name="profile_section_sync_privacy">Sync &amp; Privacy</string>
    <string name="profile_sync_privacy_subtitle">Choose what to save online</string>
    <string name="profile_sync_local_default_note">By default your data stays only on this device. Enable only what you want to save online. Photos stay local unless you enable photo sync. Changes take effect on the next save.</string>
    <string name="profile_sync_geo_points_title">Geographic data</string>
    <string name="profile_sync_geo_points_desc">Title, description, coordinates, emoji, tags and rating saved online</string>
    <string name="profile_sync_photos_title">Photos</string>
    <string name="profile_sync_photos_desc">Photos are uploaded online as a backup</string>
    <string name="backup_error_export">Export error</string>
    <string name="backup_error_import">Import error</string>
